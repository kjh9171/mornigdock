{
  "version": 2,
  "name": "mornigdock",
  "framework": null,
  "installCommand": "npm run install:all",
  "buildCommand": "npm run build",
  "outputDirectory": "frontend/dist",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "backend/src/index.ts"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ],
  "crons": [
    {
      "path": "/api/news/fetch",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/stocks/fetch",
      "schedule": "0 * * * *"
    }
  ]
}
