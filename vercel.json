{
  "version": 2,
  "name": "mornigdock",
  "builds": [
    {
      "src": "backend/src/index.ts",
      "use": "@vercel/node",
      "config": {
        "includeFiles": ["backend/src/**"]
      }
    },
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "backend/src/index.ts"
    },
    {
      "source": "/(.*)",
      "destination": "frontend/$1"
    }
  ],
  "crons": [
    {
      "path": "/api/news/fetch",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/stocks/fetch",
      "schedule": "0 * * * *"
    }
  ]
}
