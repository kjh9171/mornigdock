{
  "version": 2,
  "name": "mornigdock",
  "framework": "vite",
  "installCommand": "npm install --legacy-peer-deps --include=dev",
  "buildCommand": "npm run build",
  "outputDirectory": "frontend/dist",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "backend/src/index.ts"
    },
    {
      "source": "/(.*)",
      "destination": "frontend/dist/$1"
    }
  ],
  "crons": [
    {
      "path": "/api/news/fetch",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/stocks/fetch",
      "schedule": "0 * * * *"
    }
  ]
}
