{
  "name": "mornigdock-monorepo",
  "private": true,
  "packageManager": "npm@10.9.0",
  "engines": {
    "node": ">=22.16.0",
    "npm": ">=10.0.0"
  },
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "install:all": "npm install",
    "build:frontend": "npm run build -w frontend",
    "build:backend": "npm run build -w backend",
    "build": "npm run build:frontend && npm run build:backend"
  },
  "overrides": {
    "vite": "^7.3.1"
  }
}
